# Mighty CRM production environment template
# Copy to .env and change every secret before deployment.

ENVIRONMENT=production
DEBUG=false
APP_PORT=8080

POSTGRES_DB=mighty_crm
POSTGRES_USER=mightycrm
POSTGRES_PASSWORD=change-me-long-random-postgres-password
DATABASE_URL=postgresql+psycopg2://mightycrm:change-me-long-random-postgres-password@postgres:5432/mighty_crm
AUTO_CREATE_TABLES=false

SECRET_KEY=change-me-use-openssl-rand-hex-32-or-longer
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
PASSWORD_MIN_LENGTH=10

FRONTEND_ORIGIN=https://crm.mightymax.ai
CORS_ORIGINS=https://crm.mightymax.ai,http://localhost:5173

PROVIDER_WEBHOOK_SECRET=change-me-provider-webhook-secret
OPENCLAW_WEBHOOK_SECRET=change-me-openclaw-webhook-secret
WEBHOOK_TIMESTAMP_TOLERANCE_SECONDS=300

REDIS_URL=redis://redis:6379/0
WORKER_ENABLED=true
WORKER_POLL_SECONDS=5
WEB_CONCURRENCY=2
LOG_LEVEL=INFO

# First owner bootstrap. Used only by scripts/create_owner.py.
OWNER_EMAIL=owner@mightymax.ai
OWNER_PASSWORD=change-me-admin-password
OWNER_ORG_NAME=MightyMax
